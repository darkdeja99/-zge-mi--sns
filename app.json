{
  "expo": {
    "name": "ozgecmis-sns",
    "slug": "ozgecmis-sns",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon_deneme_3.png",
    "scheme": "ozgecmissns",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.darkdeja99.ozgecmissns",
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f2027",
        "foregroundImage": "./assets/images/icon_deneme_3.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": true,
      "package": "com.darkdeja99.ozgecmissns",
      "versionCode": 2
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0f2027",
          "dark": {
            "backgroundColor": "#0f2027"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sharing",
      "expo-status-bar",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafınızı güncellemek ve sohbetlerde fotoğraf gönderebilmek için galerinize erişmemiz gerekiyor.",
          "cameraPermission": "Profil fotoğrafınızı güncellemek ve sohbetlerde fotoğraf gönderebilmek için kameranıza erişmemiz gerekiyor."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "4c9aa5ab-baf3-4395-a985-32668f506337"
      }
    },
    "owner": "darkdeja99"
  }
}
